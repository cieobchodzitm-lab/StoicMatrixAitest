# Stoic-Matrix-Layer3 configuration example
# Copy this file to layer3.yaml and adjust for your environment.

chroma:
  host: localhost
  port: 8000
  persist_directory: ./chroma_data   # local persistent store (dev)

embedding_client:
  base_url: http://localhost:11434    # Ollama / Layer2 endpoint
  model: nomic-embed-text
  timeout_sec: 30

memory_manager:
  short_term_capacity: 100           # max records in working memory
  collection_prefix: stoic.l3
