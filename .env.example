# ==============================================================
# L7 CNOTA Dashboard — Environment Variables
# Copy to .env and fill in real values before running
# ==============================================================

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://cnota:password@localhost:5432/cnota
POSTGRES_USER=cnota
POSTGRES_PASSWORD=password
POSTGRES_DB=cnota
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── LLM / Ollama ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=30

# ── Solana / L7 Bridge ────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_KEYPAIR_PATH=/home/user/.config/solana/id.json
SOLANA_PROGRAM_ID=
L7_BRIDGE_PROGRAM_ID=
L7_BRIDGE_RPC_URL=
L7_TOKEN_MINT_ADDRESS=
L7_TREASURY_ADDRESS=

# ── NFT / Metaplex ────────────────────────────────────────────
METAPLEX_RPC_URL=https://api.devnet.solana.com
METADATA_BASE_URI=https://huggingface.co/spaces/cieobchodzitm/l7-cnota-dashboard/resolve/main/metadata/
NFT_COLLECTION_ADDRESS=
NFT_CREATOR_ADDRESS=
NFT_ROYALTY_BASIS_POINTS=500

# ── AgentOps ──────────────────────────────────────────────────
AGENTOPS_API_KEY=
AGENTOPS_BASE_URL=https://api.agentops.ai
AGENTOPS_ENV=production
AGENTOPS_TAGS=l7,cnota,virtue

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=cnota_vectors
CHROMA_PERSIST_DIR=/data/chroma

# ── FastAPI / App ─────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=7860
APP_ENV=production
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=false
APP_LOG_LEVEL=info
ALLOWED_ORIGINS=*

# ── HuggingFace ───────────────────────────────────────────────
HF_TOKEN=
HF_SPACE_ID=cieobchodzitm/l7-cnota-dashboard
HF_CACHE_DIR=/home/user/.cache/huggingface

# ── Crisis Agents ─────────────────────────────────────────────
CRISIS_AGENT_ENABLED=false
CRISIS_AGENT_MODEL=llama3
CRISIS_THRESHOLD_SCORE=150
CRISIS_ALERT_WEBHOOK=

# ── Governance ────────────────────────────────────────────────
GOVERNANCE_CONTRACT_ADDRESS=
GOVERNANCE_VOTE_WEIGHT_SOPHIA=0.25
GOVERNANCE_VOTE_WEIGHT_ANDREIA=0.25
GOVERNANCE_VOTE_WEIGHT_DIKAIOSYNE=0.25
GOVERNANCE_VOTE_WEIGHT_SOPHROSYNE=0.25
GOVERNANCE_EPOCH_SECONDS=604800

# ── Virtue Scoring Weights ────────────────────────────────────
VIRTUE_WEIGHT_SOPHIA=0.25
VIRTUE_WEIGHT_ANDREIA=0.25
VIRTUE_WEIGHT_DIKAIOSYNE=0.25
VIRTUE_WEIGHT_SOPHROSYNE=0.25
VIRTUE_SCORE_MULTIPLIER=1.0
VIRTUE_DECAY_RATE=0.01

# ── IPFS / Storage ────────────────────────────────────────────
IPFS_GATEWAY=https://ipfs.io/ipfs/
PINATA_API_KEY=
PINATA_SECRET_KEY=
ARWEAVE_KEY_FILE=

# ── Redis / Cache ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
